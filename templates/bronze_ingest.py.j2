import dlt
from dlt.destinations import bigquery
import pandas as pd
from datetime import datetime
import requests
import sqlalchemy as sa

# Configure BigQuery destination (credentials should be set via environment or config)
pipeline = dlt.pipeline(
    pipeline_name="{{ pipeline_name }}",
    destination=bigquery(),
    dataset_name="bronze"
)

@dlt.resource(name="{{ destination_table }}", write_disposition="replace")
def load_bronze_data():
    """
    Load data from {{ source_type }} source to Bronze layer in BigQuery.

    Source: {{ source_path }}
    Destination: bronze.{{ destination_table }}
    """
    try:
        # Extract data based on source type
        if "{{ source_type }}".lower() == 'csv':
            df = pd.read_csv("{{ source_path }}")

        elif "{{ source_type }}".lower() == 'parquet':
            df = pd.read_parquet("{{ source_path }}")

        elif "{{ source_type }}".lower() == 'json':
            df = pd.read_json("{{ source_path }}")

        elif "{{ source_type }}".lower() == 'database':
            # For MSSQL or other databases
            engine = sa.create_engine("{{ source_path }}")  # e.g., mssql+pyodbc://...
            df = pd.read_sql("SELECT * FROM {{ source_table }}", engine)

        elif "{{ source_type }}".lower() == 'api':
            # For REST APIs
            response = requests.get("{{ source_path }}")
            response.raise_for_status()
            data = response.json()
            df = pd.DataFrame(data)  # Assuming JSON array

        else:
            raise ValueError(f"Unsupported source type: {{ source_type }}")

        # Add ingestion metadata
        df["_ingestion_timestamp"] = datetime.utcnow()
        df["_source_system"] = "{{ source_system }}"

        # Yield data for dlt to load
        yield df

    except Exception as e:
        print(f"Error during data loading: {str(e)}")
        raise

if __name__ == "__main__":
    # Run the pipeline
    pipeline.run(load_bronze_data())
    print(f"Successfully loaded data to bronze.{{ destination_table }}")

